{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/snapshot-mrr",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/cron/refresh-current-month-snapshot",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/expire-reservations",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/clean-expired-email-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/run-data-retention",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/expire-unverified-orgs",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/zatca-report",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/mark-overdue-installments",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/expire-trials",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/process-dunning",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/apply-scheduled-plan-changes",
      "schedule": "0 1 * * *"
    }
  ]
}
