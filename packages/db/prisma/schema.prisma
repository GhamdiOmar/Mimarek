// ═══════════════════════════════════════════════════════════════════════════════
// COMMERCIALIZATION LAYER — Plans, Subscriptions, Payments, Invoicing
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  PAUSED
  CANCELED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum EntitlementType {
  BOOLEAN // Feature on/off (e.g., cmms.access)
  LIMIT // Numeric cap (e.g., units.max = 500)
  METERED // Usage-based tracking (future)
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum ZatcaStatus {
  NOT_APPLICABLE
  PENDING
  CLEARED
  REPORTED
  REJECTED
}

// ─── ZATCA Phase-2 e-invoicing enums (R2 — Track A) ───────────────────────────
enum ZatcaEnvironment {
  SANDBOX
  SIMULATION
  PRODUCTION
}

enum ZatcaEgsStatus {
  DRAFT // created, no CSR yet
  PENDING // CSR submitted / compliance CSID issued, not production-ready
  ACTIVE // production (or sandbox-production) CSID issued — locked (D30)
  RESET // platform-revoked; tenant must re-onboard
}

enum ZatcaDocumentType {
  TAX_INVOICE
  SIMPLIFIED
  CREDIT_NOTE
  DEBIT_NOTE
  RECEIPT
}

// Per-attempt clearance/report outcome (ZatcaClearanceLog.outcome). Distinct from
// ZatcaStatus (the document lifecycle field) — no overlap (plan D8/#8).
enum ZatcaClearanceOutcome {
  CLEARED
  CLEARED_WITH_WARNINGS
  REPORTED
  REJECTED
  TRANSPORT_ERROR
}

// ─── ZATCA tax-mapping enums (R3 — Track B, D16) ──────────────────────────────
// VAT category per ZATCA Phase-2 (S/Z/E/O). OrgZatcaTaxConfig stores configured
// intent; the resolver that reads it to classify a document line is R4.
enum VatCategory {
  STANDARD // S — standard-rated 15%
  ZERO // Z — zero-rated
  EXEMPT // E — exempt (residential lease, VATEX-SA-30)
  OUT_OF_SCOPE // O — outside VAT scope (sale/RETT, refundable deposit)
}

// Tenant charge purpose the tax mapping keys onto (no such taxonomy exists on the
// tenant-charge tables today — introduced here for the R4 issuance classifier).
enum ZatcaChargeType {
  RENT
  SERVICE_FEE
  DEPOSIT
  SALE
  OTHER
}

enum TransactionStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum CouponType {
  PERCENTAGE // e.g., 20% off
  FIXED_AMOUNT // e.g., 100 SAR off
}

// ─── Plan (commercial package definition) ────────────────────────────────────

model Plan {
  id            String   @id @default(cuid())
  slug          String   @unique // "starter", "professional", "enterprise"
  nameEn        String // Display name (English)
  nameAr        String // Display name (Arabic)
  descriptionEn String?
  descriptionAr String?
  priceMonthly  Decimal  @default(0) @db.Decimal(14, 2) // SAR per month
  priceAnnual   Decimal  @default(0) @db.Decimal(14, 2) // SAR per year (discounted)
  currency      String   @default("SAR")
  trialDays     Int      @default(14)
  isPublic      Boolean  @default(true) // Visible on pricing page
  isDefault     Boolean  @default(false) // Assigned to new orgs
  sortOrder     Int      @default(0)
  features      Json? // Marketing feature list for pricing page
  metadata      Json? // Additional config (e.g., SLA tier, support channel)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entitlements  PlanEntitlement[]
  subscriptions Subscription[]
  coupons       Coupon[]          @relation("CouponPlans")

  @@index([isPublic, sortOrder])
}

// ─── Plan Entitlement (feature/limit per plan) ──────────────────────────────

model PlanEntitlement {
  id         String          @id @default(cuid())
  planId     String
  plan       Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey String // e.g., "units.max", "cmms.access", "reports.export"
  type       EntitlementType
  value      String // "true"/"false" for BOOLEAN, numeric string for LIMIT/METERED
  metadata   Json? // Additional context (e.g., description, display label)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

// ─── Subscription (org enrollment in a plan) ────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String
  // Restrict (financial parent, consistent with its Restrict children SubscriptionEvent /
  // SubscriptionMrrSnapshot): a billing subtree is not silently cascade-deleted with an org.
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])
  status             SubscriptionStatus @default(TRIALING)
  billingCycle       BillingCycle       @default(MONTHLY)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  canceledAt         DateTime?
  cancelReason       String?
  pausedAt           DateTime?
  resumesAt          DateTime?
  nextBillingDate    DateTime?
  priceAtRenewal     Decimal?           @db.Decimal(14, 2) // Locked-in price for next renewal
  metadata           Json?
  mrrSar             Decimal?           @db.Decimal(14, 2) // ex-VAT, denormalized monthly recurring revenue at current price
  acquiredMonth      String? // "YYYY-MM", set on first TRIALING transition (or ACTIVE if no trial)
  activatedMonth     String? // "YYYY-MM", set on first ACTIVE transition
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  events       SubscriptionEvent[]
  invoices     Invoice[]
  mrrSnapshots SubscriptionMrrSnapshot[]

  @@index([organizationId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([acquiredMonth])
  @@index([activatedMonth])
}

// ─── Subscription Event (audit trail for status transitions) ────────────────

model SubscriptionEvent {
  id             String              @id @default(cuid())
  subscriptionId String
  subscription   Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  fromStatus     SubscriptionStatus?
  toStatus       SubscriptionStatus
  triggeredBy    String // "system", "webhook", "admin:<userId>", "user:<userId>"
  reason         String?
  metadata       Json? // Additional context (e.g., gateway response, dunning attempt #)
  eventCategory  String? // NEW | EXPANSION | CONTRACTION | CHURN | REACTIVATION | TRIAL_STARTED | TRIAL_CONVERTED | REFUND_ADJUSTMENT
  mrrDeltaSar    Decimal?            @db.Decimal(14, 2) // Signed ex-VAT delta; positive for new/expansion, negative for contraction/churn/refund
  idempotencyKey String?             @unique // Format: "<subscriptionId>:<occurredAt>:<eventCategory>"
  createdAt      DateTime            @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
  @@index([eventCategory, createdAt])
}

// ─── Subscription MRR Snapshot (per-month per-sub denormalised MRR) ─────────

model SubscriptionMrrSnapshot {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  subscriptionId String
  subscription   Subscription       @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  snapshotMonth  String // "YYYY-MM" — first of month captured
  mrrSar         Decimal            @default(0) @db.Decimal(14, 2) // ex-VAT MRR at snapshot time
  status         SubscriptionStatus // Subscription status at snapshot time
  planId         String // Plan ID at snapshot time
  createdAt      DateTime           @default(now())

  @@unique([subscriptionId, snapshotMonth])
  @@index([snapshotMonth, status])
  @@index([organizationId, snapshotMonth])
}

// ─── Entitlement Override (per-org exceptions for enterprise/custom deals) ──

model EntitlementOverride {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureKey     String
  type           EntitlementType
  value          String
  reason         String? // Why this override exists (e.g., "Enterprise contract #123")
  grantedBy      String? // userId of admin who granted
  expiresAt      DateTime? // Null = permanent
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organizationId, featureKey])
  @@index([organizationId])
}

// ─── Invoice ────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique // Sequential per ZATCA (e.g., INV-2026-00001)
  uuid           String        @unique @default(uuid()) // UUID v4 per ZATCA
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  status         InvoiceStatus @default(DRAFT)
  billingCycle   BillingCycle?
  subtotal       Decimal       @db.Decimal(14, 2) // Before VAT
  vatRate        Decimal       @default(0.15) @db.Decimal(6, 4) // 15% Saudi VAT (rate, not money)
  vatAmount      Decimal       @db.Decimal(14, 2)
  discountAmount Decimal       @default(0) @db.Decimal(14, 2)
  total          Decimal       @db.Decimal(14, 2) // subtotal + vatAmount - discountAmount
  currency       String        @default("SAR")
  issuedAt       DateTime?
  dueDate        DateTime?
  paidAt         DateTime?
  notes          String?

  // ZATCA e-invoicing fields
  zatcaStatus       ZatcaStatus        @default(NOT_APPLICABLE)
  zatcaHash         String? // Previous invoice hash (for chaining)
  zatcaQrCode       String? // Base64 encoded QR
  xmlContent        String? // Signed ZATCA XML
  zatcaSubmittedAt  DateTime?
  zatcaClearedAt    DateTime?
  // R2 (Track A): document type + credit-note linkage + the ZATCA-stamped cleared XML.
  documentType      ZatcaDocumentType? @default(TAX_INVOICE)
  originalInvoiceId String? // set on CREDIT_NOTE/DEBIT_NOTE → the original cleared invoice
  originalInvoice   Invoice?           @relation("InvoiceAdjustments", fields: [originalInvoiceId], references: [id])
  adjustments       Invoice[]          @relation("InvoiceAdjustments")
  clearedXml        String? // ZATCA-stamped cleared XML (standard/clearance; QR parsed from here, D28)

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems    InvoiceLineItem[]
  transactions PaymentTransaction[]

  @@index([organizationId])
  @@index([status])
  @@index([issuedAt])
  @@index([invoiceNumber])
  @@index([dueDate, status]) // AR aging queries
}

// ─── Invoice Line Item ──────────────────────────────────────────────────────

model InvoiceLineItem {
  id            String  @id @default(cuid())
  invoiceId     String
  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description   String
  descriptionAr String?
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(14, 2)
  vatRate       Decimal @default(0.15) @db.Decimal(6, 4) // rate, not money
  vatAmount     Decimal @db.Decimal(14, 2)
  total         Decimal @db.Decimal(14, 2) // quantity * unitPrice + vatAmount
  sortOrder     Int     @default(0)

  @@index([invoiceId])
}

// ─── ZATCA tenant document (R4 — Track C tenant issuance) ─────────────────────
// A real ZATCA document a TENANT issues to ITS customer (separate from the global
// SaaS Invoice, Track A). Per-EGS display number; a stable per-document uuid minted
// once, never on retry (L24); the buyer snapshot is immutable at issuance (cleared
// XML is immutable, so a later Customer edit does NOT re-clear). Receipts (residential
// rent / sale / deposit) carry no QR/XML/clearance (D21). generate-rls auto-covers it.

enum CustomerKind {
  INDIVIDUAL
  COMPANY
}

enum TenantDocumentKind {
  RENT_INSTALLMENT
  CONTRACT_INSTALLMENT
  CREDIT_NOTE
}

model TenantDocument {
  id             String       @id @default(cuid())
  organizationId String
  // Restrict (not Cascade): a ZATCA tax document is a legally-retained record (ZATCA + PDPL) —
  // deleting its org/EGS must NOT silently destroy issued invoices. An EGS is RESET, never deleted.
  organization   Organization @relation("OrgTenantDocuments", fields: [organizationId], references: [id], onDelete: Restrict)
  egsUnitId      String
  egsUnit        ZatcaEgsUnit @relation("EgsTenantDocuments", fields: [egsUnitId], references: [id], onDelete: Restrict)

  documentNumber String // per-EGS display number (sequence scope = egs:<egsUnitId>)
  uuid           String             @unique @default(uuid()) // stable per-document UUID (L24)
  documentType   ZatcaDocumentType  @default(TAX_INVOICE)
  kind           TenantDocumentKind
  chargeType     ZatcaChargeType

  // Polymorphic source (one set per kind; typed FKs keep referential integrity)
  rentInstallmentId        String?
  rentInstallment          RentInstallment?        @relation("RentInstallmentTenantDocs", fields: [rentInstallmentId], references: [id])
  paymentPlanInstallmentId String?
  paymentPlanInstallment   PaymentPlanInstallment? @relation("PpiTenantDocs", fields: [paymentPlanInstallmentId], references: [id])
  sourceKey                String? // idempotency seam (matches the ledger dedup key)

  // Buyer snapshot — immutable at issuance (a later Customer edit does NOT re-clear)
  customerId     String?
  customer       Customer? @relation("CustomerTenantDocs", fields: [customerId], references: [id])
  buyerName      String?
  buyerNameAr    String?
  buyerVatNumber String?
  buyerCrNumber  String?
  buyerAddress   Json?

  unitType UnitType?

  // Money (mirrors Invoice)
  subtotal       Decimal     @db.Decimal(14, 2)
  vatCategory    VatCategory
  vatRate        Decimal     @default(0.15) @db.Decimal(6, 4) // rate, not money
  vatAmount      Decimal     @db.Decimal(14, 2)
  discountAmount Decimal     @default(0) @db.Decimal(14, 2)
  total          Decimal     @db.Decimal(14, 2)
  currency       String      @default("SAR")

  status         InvoiceStatus @default(DRAFT)
  zatcaStatus    ZatcaStatus   @default(NOT_APPLICABLE)
  needsBuyerData Boolean       @default(false) // held: awaiting B2B buyer VAT/CR/address (D18)

  // ZATCA fields (mirror Invoice)
  zatcaHash        String?
  zatcaQrCode      String?
  xmlContent       String?
  clearedXml       String?
  zatcaSubmittedAt DateTime?
  zatcaClearedAt   DateTime?

  // Credit-note linkage (verbatim positive amounts, type 381, no sign-flip — L23)
  originalDocumentId String?
  originalDocument   TenantDocument?  @relation("TenantDocAdjustments", fields: [originalDocumentId], references: [id])
  adjustments        TenantDocument[] @relation("TenantDocAdjustments")

  issuedAt  DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems     TenantDocumentLineItem[]
  clearanceLogs ZatcaClearanceLog[]

  @@unique([egsUnitId, documentNumber])
  @@index([organizationId])
  @@index([egsUnitId])
  @@index([zatcaStatus])
  @@index([organizationId, status])
  @@index([organizationId, zatcaStatus])
  @@index([rentInstallmentId])
  @@index([paymentPlanInstallmentId])
  @@index([customerId])
}

model TenantDocumentLineItem {
  id            String         @id @default(cuid())
  documentId    String
  document      TenantDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  description   String
  descriptionAr String?
  quantity      Int            @default(1)
  unitPrice     Decimal        @db.Decimal(14, 2)
  vatRate       Decimal        @default(0.15) @db.Decimal(6, 4) // rate, not money
  vatAmount     Decimal        @db.Decimal(14, 2)
  total         Decimal        @db.Decimal(14, 2)
  sortOrder     Int            @default(0)

  @@index([documentId])
}

// ─── Payment Transaction ────────────────────────────────────────────────────

model PaymentTransaction {
  id              String            @id @default(cuid())
  invoiceId       String
  invoice         Invoice           @relation(fields: [invoiceId], references: [id])
  paymentMethodId String?
  paymentMethod   PaymentMethod?    @relation(fields: [paymentMethodId], references: [id])
  gateway         String // "moyasar", "hyperpay", "paytabs"
  gatewayRef      String? // Gateway-specific transaction ID
  amount          Decimal           @db.Decimal(14, 2)
  currency        String            @default("SAR")
  status          TransactionStatus @default(PENDING)
  failureReason   String?
  refundedAmount  Decimal?          @db.Decimal(14, 2)
  metadata        Json? // Raw gateway response
  initiatedAt     DateTime          @default(now())
  completedAt     DateTime?

  @@index([invoiceId])
  @@index([gatewayRef])
  @@index([status])
}

// ─── Payment Method (tokenized card per org) ────────────────────────────────

model PaymentMethod {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gateway        String // "moyasar", "hyperpay"
  tokenId        String // Gateway token reference
  brand          String? // "mada", "visa", "mastercard", "applepay"
  lastFourDigits String?
  expiryMonth    Int?
  expiryYear     Int?
  holderName     String?
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  transactions PaymentTransaction[]

  @@index([organizationId])
}

// ─── Gateway Config (system-level gateway credentials) ──────────────────────

model GatewayConfig {
  id              String   @id @default(cuid())
  gateway         String   @unique // "moyasar", "hyperpay", "paytabs"
  displayName     String
  isEnabled       Boolean  @default(false)
  isPrimary       Boolean  @default(false)
  supportedBrands Json? // ["mada", "visa", "mastercard", "applepay"]
  config          Json? // Non-secret config (e.g., mode: "test"/"live")
  // Secret keys stored in env vars, NOT here
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Webhook Event (idempotency log) ────────────────────────────────────────

model WebhookEvent {
  id          String    @id @default(cuid())
  gateway     String // "moyasar", "hyperpay", "paytabs"
  eventId     String // Gateway event ID (for idempotency)
  eventType   String // e.g., "payment.succeeded", "payment.failed"
  payload     Json // Raw webhook payload
  processedAt DateTime?
  error       String? // Processing error message if failed
  createdAt   DateTime  @default(now())

  @@unique([gateway, eventId])
  @@index([gateway, eventType])
  @@index([createdAt])
}

// ─── DataRetentionRun (PDPL/NDMO destruction audit) ─────────────────────────
// Append-only audit row per retention sweep (cron or manual). `results` holds the
// per-category deleted-count breakdown as JSON. No FK to User on triggeredById —
// kept as a denormalized snapshot so a run record survives the actor's deletion.

model DataRetentionRun {
  id               String    @id @default(cuid())
  trigger          String // "CRON" | "MANUAL"
  dryRun           Boolean   @default(false)
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  status           String    @default("RUNNING") // RUNNING|SUCCESS|SKIPPED_LOCKED|FAILED
  results          Json?
  totalDeleted     Int       @default(0)
  error            String?   @db.Text
  triggeredById    String?
  triggeredByEmail String?
  createdAt        DateTime  @default(now())

  @@index([startedAt])
  @@index([status])
}

// ─── Coupon (code-based discount) ───────────────────────────────────────────

model Coupon {
  id                String     @id @default(cuid())
  code              String     @unique
  descriptionEn     String?
  descriptionAr     String?
  type              CouponType
  value             Decimal    @db.Decimal(14, 2) // Percentage (0-100) or fixed SAR amount — (14,2) covers both
  currency          String     @default("SAR")
  maxRedemptions    Int? // Null = unlimited
  currentUses       Int        @default(0)
  validFrom         DateTime   @default(now())
  validUntil        DateTime?
  isActive          Boolean    @default(true)
  minPurchaseAmount Decimal?   @db.Decimal(14, 2) // Minimum invoice amount
  applicableCycles  Json? // ["MONTHLY", "ANNUAL"] or null = all
  metadata          Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  plans       Plan[]             @relation("CouponPlans")
  redemptions CouponRedemption[]
  invoices    Invoice[]

  @@index([code])
  @@index([isActive, validFrom, validUntil])
}

// ─── Coupon Redemption (usage tracking per org) ─────────────────────────────

model CouponRedemption {
  id              String       @id @default(cuid())
  couponId        String
  coupon          Coupon       @relation(fields: [couponId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  discountApplied Decimal      @db.Decimal(14, 2) // Actual SAR discount given
  redeemedAt      DateTime     @default(now())

  // QA-SEC-02: one redemption per coupon per org (prevents double-redeem race).
  // SAFE on the populated DB only if no duplicate (couponId, organizationId) rows
  // exist — run the precheck SELECT in 2026-06-v4.28-manual-steps.md before `db push`.
  @@unique([couponId, organizationId])
  @@index([couponId])
  @@index([organizationId])
}

// ─── Customer Activity Timeline (CRM) ─────────────────────────────────────────

model CustomerActivity {
  id          String       @id @default(cuid())
  customerId  String
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        ActivityType
  note        String
  createdById String
  createdBy   User         @relation("ActivityCreator", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())

  @@index([customerId])
  @@index([createdById])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  SITE_VISIT
  NOTE
  WHATSAPP
}

// ─── Deal (CRM pipeline entity — table preserved as CustomerPropertyInterest) ──

model Deal {
  id                String         @id @default(cuid())
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  unitId            String
  unit              Unit           @relation(fields: [unitId], references: [id])
  intent            PropertyIntent
  status            InterestStatus @default(ACTIVE)
  stage             DealStage      @default(NEW)
  value             Decimal?       @db.Decimal(14, 2) // SAR deal/opportunity value (pipeline weighting with probability)
  probability       Int?
  expectedCloseDate DateTime?
  lostReason        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt

  @@index([customerId])
  @@index([unitId])
  @@index([stage])
  @@map("CustomerPropertyInterest")
}

enum DealStage {
  NEW
  QUALIFIED
  VIEWING
  NEGOTIATION
  RESERVED
  WON
  LOST
}

enum PropertyIntent {
  BUY
  RENT
}

enum InterestStatus {
  ACTIVE // Customer is currently interested
  CONVERTED // Converted to a Deal (reservation created)
  DROPPED // Customer no longer interested
}

// ─── System SEO & Brand Configuration (singleton: id = "system") ─────────────

model SystemConfig {
  id String @id @default("system")

  // SEO Metadata
  siteTitle         String?
  siteTitleTemplate String?
  siteDescriptionAr String?
  siteDescriptionEn String?
  canonicalUrl      String?

  // Open Graph
  ogTitle       String?
  ogDescription String?
  ogType        String? @default("website")
  ogLocale      String? @default("ar_SA")

  // Twitter / X
  twitterCard   String? @default("summary_large_image")
  twitterHandle String?

  // Brand Assets (CDN URLs via UploadThing)
  faviconUrl        String?
  appleTouchIconUrl String?
  ogImageUrl        String?
  logoUrl           String?
  logoLightUrl      String?
  logoDarkUrl       String?

  // Tag Management (GTM recommended — manages all pixels)
  gtmContainerId   String?
  ga4MeasurementId String?
  gadsConversionId String?

  // Webmaster Verification
  gscVerificationCode  String?
  bingVerificationCode String?

  // robots.txt rules (JSON: MetadataRoute.Robots["rules"])
  robotsTxtRules String? @db.Text

  // Organization Schema.org
  schemaOrgName      String?
  schemaOrgLogoUrl   String?
  schemaOrgTwitter   String?
  schemaOrgLinkedIn  String?
  schemaOrgInstagram String?

  // ─── REGA / Real-Estate Compliance ──────────────────────────────────────────
  // Mimarek's own REGA electronic-real-estate-platform FAL license number
  // (required to lawfully host marketplace advertisements; REGA mandates the
  // license be displayed). Surfaced on the login / landing pages as a compliance
  // affordance and set by platform admin. Placeholder until issued.
  regaPlatformFalLicense String?

  // ─── Marketplace Conveyance (P3 reserve-and-buy) ─────────────────────────────
  // Master kill-switch for the IRREVERSIBLE cross-org ownership transfer
  // (settlement). Ships DARK (default false): every settlement call re-reads this
  // UNCACHED from the DB, so flipping it off is an instant kill-switch. Lawful
  // activation also needs platform-FAL licensing + legal sign-off (recorded below)
  // + verified deed proof + REGA-verified seller & buyer orgs.
  marketplaceConveyanceEnabled Boolean   @default(false)
  marketplaceLegalSignoffBy    String?
  marketplaceLegalSignoffAt    DateTime?
  marketplaceLegalSignoffNote  String?   @db.Text

  // Transactional Email (Hostinger SMTP)
  emailProvider         String?   @default("HOSTINGER_SMTP")
  emailEnabled          Boolean   @default(false)
  emailFromName         String?
  emailFromAddress      String?
  emailReplyTo          String?
  smtpHost              String?   @default("smtp.hostinger.com")
  smtpPort              Int?      @default(465)
  smtpSecure            Boolean   @default(true)
  smtpUsername          String?
  smtpPasswordEncrypted String?   @db.Text
  smtpPasswordLast4     String?
  emailTestRecipient    String?
  emailLastTestAt       DateTime?
  emailLastTestStatus   String?
  emailLastTestMessage  String?   @db.Text

  // ─── Data Retention (PDPL/NDMO) — platform-admin destruction & scheduler ─────
  // Per-category retention windows (days) and the daily-scheduler controls.
  // All defaulted so a `db push` is safe on the already-populated singleton row.
  retentionAuditLogDays     Int       @default(730)
  retentionConsentLogDays   Int       @default(730)
  retentionNotificationDays Int       @default(180)
  retentionWebhookEventDays Int       @default(90)
  retentionSchedulerEnabled Boolean   @default(false)
  retentionRunHour          Int       @default(3)
  lastRetentionRunAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Marketplace — cross-org B2B unit trading ───────────────────────────────

enum MarketplaceListingStatus {
  DRAFT
  PENDING_REVIEW // P3: seller submitted; awaiting platform moderation (not buyer-visible)
  PUBLISHED
  UNDER_CONTRACT
  SOLD_TRANSFERRED
  UNPUBLISHED
  EXPIRED
  REJECTED
  SUSPENDED
}

// P3 conveyance — manual staff attestation now; API_VERIFIED reachable later with
// NO schema change (the settlement guard checks the VERIFIED value, not the method).
enum VerificationStatus {
  SELF_ASSERTED
  VERIFIED
  REJECTED
}

enum DeedProofStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum VerificationMethod {
  MANUAL_ATTESTATION
  API_VERIFIED
}

enum MarketplaceInquiryStatus {
  OPEN
  CONVERTED_TO_DEAL
  WITHDRAWN
  DECLINED
  CLOSED_WON
  CLOSED_LOST
}

enum UnitTransferStatus {
  PENDING_SETTLEMENT
  READY
  COMPLETED
  FAILED
  CANCELLED
}

enum MarketplaceComplianceStatus {
  NOT_REQUIRED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model MarketplaceListing {
  id                String                      @id @default(cuid())
  listingNumber     String                      @unique
  unitId            String
  unit              Unit                        @relation("UnitMarketplaceListings", fields: [unitId], references: [id])
  sellerOrgId       String
  sellerOrg         Organization                @relation("MarketplaceSellerListings", fields: [sellerOrgId], references: [id])
  status            MarketplaceListingStatus    @default(DRAFT)
  complianceStatus  MarketplaceComplianceStatus @default(NOT_REQUIRED)
  adLicenseNumber   String?
  sellerOrgSnapshot Json?
  // Curated public view fields — never expose raw Unit across orgs
  title             String?
  description       String?
  price             Decimal?                    @db.Decimal(14, 2)
  area              Float?
  city              String?
  district          String?
  propertyType      UnitType?
  bedrooms          Int?
  bathrooms         Int?
  buildingAge       Int?
  shortAddress      String?
  viewCount         Int                         @default(0)
  interestCount     Int                         @default(0)
  publishedAt       DateTime?
  expiresAt         DateTime?
  unpublishedReason String?
  suspendedReason   String?
  rejectedReason    String?
  inquiries         MarketplaceInquiry[]
  transfers         UnitTransferTransaction[]
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([sellerOrgId])
  @@index([status])
  @@index([unitId])
  @@index([status, expiresAt])
  @@index([status, city])
}

model MarketplaceInquiry {
  id                  String                   @id @default(cuid())
  listingId           String
  listing             MarketplaceListing       @relation(fields: [listingId], references: [id])
  buyerOrgId          String
  buyerOrg            Organization             @relation("MarketplaceBuyerInquiries", fields: [buyerOrgId], references: [id])
  sellerOrgId         String
  sellerOrg           Organization             @relation("MarketplaceSellerInquiries", fields: [sellerOrgId], references: [id])
  sellerCrmCustomerId String?
  sellerCrmCustomer   Customer?                @relation("MarketplaceInquiryCustomer", fields: [sellerCrmCustomerId], references: [id])
  status              MarketplaceInquiryStatus @default(OPEN)
  message             String?
  buyerOrgSnapshot    Json?
  reservation         Reservation?
  transfer            UnitTransferTransaction?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([listingId, buyerOrgId])
  @@index([buyerOrgId])
  @@index([sellerOrgId])
  @@index([listingId])
  @@index([status])
}

model UnitTransferTransaction {
  id            String                @id @default(cuid())
  inquiryId     String                @unique
  inquiry       MarketplaceInquiry    @relation(fields: [inquiryId], references: [id])
  listingId     String
  listing       MarketplaceListing    @relation(fields: [listingId], references: [id])
  reservationId String?
  contractId    String?
  sellerOrgId   String
  sellerOrg     Organization          @relation("MarketplaceSellerTransfers", fields: [sellerOrgId], references: [id])
  buyerOrgId    String
  buyerOrg      Organization          @relation("MarketplaceBuyerTransfers", fields: [buyerOrgId], references: [id])
  sellerUnitId  String
  buyerUnitId   String?
  status        UnitTransferStatus    @default(PENDING_SETTLEMENT)
  deedProof     MarketplaceDeedProof? // P3: 1:1 deed-transfer proof gating settlement
  failureReason String?
  settledAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([sellerOrgId])
  @@index([buyerOrgId])
  @@index([status])
}

// ─── P3 conveyance — deed-transfer proof (per transfer, 1:1) ─────────────────
// Highly sensitive: deed number + owner national-ID are AES-256-GCM encrypted at
// rest (via the canonical encrypt() path); the deed file lives in object storage,
// only its URL + SHA-256 hash are stored. A staff member attests VERIFIED, which
// advances the transfer PENDING_SETTLEMENT → READY. Settlement (READY → COMPLETED)
// requires deedProofStatus = VERIFIED + the conveyance flag ON.
model MarketplaceDeedProof {
  id                 String                  @id @default(cuid())
  transferId         String                  @unique
  transfer           UnitTransferTransaction @relation(fields: [transferId], references: [id], onDelete: Cascade)
  deedNumberEnc      String? // AES-256-GCM ciphertext — never plaintext
  ownerNationalIdEnc String? // AES-256-GCM ciphertext
  deedDocUrl         String? // object-storage URL of the uploaded deed (not the bytes)
  deedDocHash        String? // SHA-256 of the uploaded file (tamper detection)
  rettCertRef        String? // ZATCA RETT certificate reference (record-only)
  status             DeedProofStatus         @default(PENDING)
  method             VerificationMethod      @default(MANUAL_ATTESTATION)
  verifiedByUserId   String?
  verifiedAt         DateTime?
  rejectedReason     String?
  submittedAt        DateTime                @default(now())
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([status])
}

// ─── P3 conveyance — org REGA/FAL authorization (per org, 1:1) ───────────────
// An org self-asserts its REGA ad-license / FAL number; a staff member flips it to
// VERIFIED. Settlement requires BOTH the seller and buyer org to be VERIFIED (when
// the conveyance flag is ON). MANUAL_ATTESTATION now; API_VERIFIED later, no migration.
model OrgRegaAuthorization {
  id                String             @id @default(cuid())
  organizationId    String             @unique
  organization      Organization       @relation("OrgRegaAuthorization", fields: [organizationId], references: [id], onDelete: Cascade)
  regaLicenseNumber String?
  status            VerificationStatus @default(SELF_ASSERTED)
  method            VerificationMethod @default(MANUAL_ATTESTATION)
  isSeller          Boolean            @default(false)
  isBuyer           Boolean            @default(false)
  verifiedByUserId  String?
  verifiedAt        DateTime?
  expiresAt         DateTime?
  rejectedReason    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status])
}

// ─── SequenceCounter ──────────────────────────────────────────────────────────
// Atomic per-org/per-type/per-year counter for collision-free contract & invoice
// numbering. Read+bumped via `UPDATE ... RETURNING` inside the same transaction as
// the entity create (replaces count()+1 / max-lookup races). See lib/sequence.ts.
model SequenceCounter {
  id             String   @id @default(cuid())
  organizationId String
  counterType    String // e.g. "CONTRACT_SALE", "CONTRACT_LEASE", "INVOICE"
  year           Int
  value          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, counterType, year])
}

// ─── RateLimitCounter ─────────────────────────────────────────────────────────
// Postgres-backed fixed-window rate limiter (replaces per-process in-memory Maps so
// limits hold across multiple instances). Atomic upsert/increment with a TTL window;
// callers fail-open on DB error. See lib/rate-limit.ts.
model RateLimitCounter {
  key         String   @id // e.g. "login:user@example.com", "invite:<orgId>"
  count       Int      @default(0)
  windowStart DateTime @default(now())
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

// ─── ZATCA EGS unit (R2 — Track A) ────────────────────────────────────────────
// An EGS (E-invoice Generation Solution) unit holds one ZATCA identity + crypto
// chain. organizationId == NULL is THE PLATFORM EGS (Mimarek PropTech Co. as the
// seller for SaaS billing, Track A); a non-null org is a tenant's own EGS (Track B/R3).
// All secret columns are AES-256-GCM encrypted via lib/zatca-crypto (ZATCA_MASTER_KEY)
// and MUST be excluded from every client DTO via explicit Prisma `select` (D13).
model ZatcaEgsUnit {
  id                  String           @id @default(cuid())
  organizationId      String?
  organization        Organization?    @relation("OrgZatcaEgsUnits", fields: [organizationId], references: [id])
  environment         ZatcaEnvironment @default(SANDBOX)
  status              ZatcaEgsStatus   @default(DRAFT)
  // EGS identity / tax identity
  egsSerialNumber     String // 1-<sol>|2-<model>|3-<uuid>
  commonName          String
  vatNumber           String // 15-digit
  crNumber            String?
  legalNameAr         String?
  legalNameEn         String?
  nationalAddress     Json?
  invoiceTypeFlags    String           @default("1100") // CSR title flags
  industryCategory    String?
  // Per-EGS chain state (advanced via atomic CAS in the issue/clear tx, D8)
  lastIcv             Int              @default(0)
  lastInvoiceHash     String? // PIH (base64); genesis seed for the first document
  // Encrypted secrets (z1: ciphertext) — NEVER selected into a client DTO
  privateKeyPem       String?
  csrPem              String?
  complianceRequestId String?
  complianceToken     String?
  complianceSecret    String?
  productionToken     String?
  productionSecret    String?
  certificateBase64   String? // the issued CSID cert (base64 DER string for the signer)
  onboardedAt         DateTime?
  revokedAt           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  clearanceLogs   ZatcaClearanceLog[]
  branches        ZatcaBranch[]
  tenantDocuments TenantDocument[]    @relation("EgsTenantDocuments")

  // NULL org (platform) rows are distinct under NULL semantics — app logic enforces a
  // single ACTIVE platform EGS per environment, backed by partial unique indexes
  // (platform: 2026-06-zatca-platform-egs-unique.sql; tenant: zatca_egs_one_active_per_org_env, R3).
  @@unique([organizationId, environment, egsSerialNumber])
  @@index([organizationId])
  @@index([status])
}

// ─── ZATCA clearance/report attempt log (R2) ──────────────────────────────────
model ZatcaClearanceLog {
  id          String                @id @default(cuid())
  egsUnitId   String
  // Restrict: the clearance/report attempt log is a retained audit trail — an EGS with logged
  // ZATCA activity is never hard-deleted (it is RESET). The document link stays Cascade because
  // the log is meaningless without its (itself Restrict-protected) parent document.
  egsUnit     ZatcaEgsUnit          @relation(fields: [egsUnitId], references: [id], onDelete: Restrict)
  invoiceId   String? // Track A: the SaaS Invoice this attempt was for
  documentId  String? // Track C: the TenantDocument (R4)
  document    TenantDocument?       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  outcome     ZatcaClearanceOutcome
  attempt     Int                   @default(1)
  requestUuid String?
  icv         Int?
  zatcaCodes  String[] // ZATCA validation codes only (no payload/key material, D13)
  message     String? // sanitized; never carries key material or request payload
  createdAt   DateTime              @default(now())

  @@index([egsUnitId])
  @@index([invoiceId])
  @@index([documentId])
}

// ─── ZATCA branch (R3 — Track B, D15/D25) ─────────────────────────────────────
// Metadata-only in R3: stores branch identity + location. Per-branch CSR/issuance
// is R4 (egsSerialNumber/onboardedAt are reserved for then). Explicit FK model
// (NOT an implicit Prisma M2M) so generate-rls.ts auto-covers it.
model ZatcaBranch {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation("OrgZatcaBranches", fields: [organizationId], references: [id], onDelete: Cascade)
  egsUnitId       String
  egsUnit         ZatcaEgsUnit @relation(fields: [egsUnitId], references: [id], onDelete: Cascade)
  name            String // Arabic branch name
  nameEn          String?
  locationAddress Json? // national-address shape (region/city/district/streetName/buildingNumber/postalCode/additionalNumber/shortAddress)
  locationCode    String? // ZATCA branch/location code (if assigned)
  egsSerialNumber String? // reserved for R4 per-branch CSR; null in R3
  isActive        Boolean      @default(true)
  onboardedAt     DateTime? // R4: set when the branch EGS is issued
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  taxConfigs OrgZatcaTaxConfig[]

  @@unique([organizationId, egsUnitId, locationCode])
  @@index([organizationId])
  @@index([egsUnitId])
}

// ─── ZATCA tax mapping (R3 — Track B, D16) ────────────────────────────────────
// Configured INTENT only. The resolver that reads this to classify a document
// line (issueDocumentForCharge) lands in R4 — there is no R3 runtime reader.
model OrgZatcaTaxConfig {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation("OrgZatcaTaxConfig", fields: [organizationId], references: [id], onDelete: Cascade)
  unitType        UnitType? // null = applies to all unit types
  chargeType      ZatcaChargeType? // null = applies to all charges
  branchId        String? // future per-branch scope
  branch          ZatcaBranch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  vatCategory     VatCategory      @default(STANDARD)
  vatRate         Decimal?         @db.Decimal(6, 4) // null = ZATCA standard for the category
  eInvoiceEnabled Boolean          @default(true) // residential rent = false (no e-invoice)
  notes           String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([organizationId, unitType, chargeType, branchId])
  @@index([organizationId])
  @@index([organizationId, unitType])
}
