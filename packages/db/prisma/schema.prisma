// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Organization (MOC Commercial Registration aligned) ───────────────────────

model Organization {
  id                  String                      @id @default(cuid())
  name                String
  nameArabic          String? // Official entity name in Arabic
  nameEnglish         String? // Official entity name in English
  logoUrl             String? // Org logo (Track C: seller branding on issued ZATCA documents)
  tradeNameArabic     String? // Trade name in Arabic
  tradeNameEnglish    String? // Trade name in English
  crNumber            String?                     @unique // Commercial Registration Number (10 digits)
  unifiedNumber       String?                     @unique // Unified entity number (10 digits)
  vatNumber           String?                     @unique // VAT number (15 digits, starts/ends with 3)
  type                OrgType                     @default(DEVELOPER)
  entityType          EntityType? // MOC: establishment, company, branch, etc.
  legalForm           LegalForm? // MOC: LLC, JSC, sole proprietorship, etc.
  registrationStatus  RegistrationStatus? // MOC: active, expired, suspended, etc.
  appStatus           OrgAppStatus                @default(ACTIVE) // Mimarek app-level org lifecycle (E1)
  registrationDate    DateTime? // CR registration date
  expiryDate          DateTime? // CR expiry date
  capitalAmountSar    Decimal?                    @db.Decimal(14, 2) // Declared capital in SAR
  mainActivityCode    String? // ISIC activity code
  mainActivityNameAr  String? // Primary activity name (Arabic)
  contactInfo         Json? // {mobileNumber, phoneNumber, email, websiteUrl}
  nationalAddress     Json? // Saudi national address object
  managerInfo         Json? // {managerName, managerId, managerRole}
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  users               User[]
  units               Unit[]                      @relation("UnitOrganization")
  customers           Customer[]
  documents           Document[]
  maintenanceRequests MaintenanceRequest[]
  preventivePlans     PreventiveMaintenancePlan[]
  permissionRequests  PermissionRequest[]
  supportTickets      SupportTicket[]
  invitations         Invitation[]
  joinRequests        JoinRequest[]               @relation("OrgJoinRequests")

  // ── Commercialization relations ──
  subscriptions        Subscription[]
  mrrSnapshots         SubscriptionMrrSnapshot[]
  entitlementOverrides EntitlementOverride[]
  paymentMethods       PaymentMethod[]
  invoices             Invoice[]
  couponRedemptions    CouponRedemption[]
  zatcaEgsUnits        ZatcaEgsUnit[]            @relation("OrgZatcaEgsUnits")
  zatcaBranches        ZatcaBranch[]             @relation("OrgZatcaBranches")
  zatcaTaxConfigs      OrgZatcaTaxConfig[]       @relation("OrgZatcaTaxConfig")
  tenantDocuments      TenantDocument[]          @relation("OrgTenantDocuments")

  // ── Marketplace relations ──
  marketplaceSellerListings  MarketplaceListing[]      @relation("MarketplaceSellerListings")
  marketplaceBuyerInquiries  MarketplaceInquiry[]      @relation("MarketplaceBuyerInquiries")
  marketplaceSellerInquiries MarketplaceInquiry[]      @relation("MarketplaceSellerInquiries")
  marketplaceSellerTransfers UnitTransferTransaction[] @relation("MarketplaceSellerTransfers")
  marketplaceBuyerTransfers  UnitTransferTransaction[] @relation("MarketplaceBuyerTransfers")
  regaAuthorization          OrgRegaAuthorization?     @relation("OrgRegaAuthorization")

  // ── DataTable saved-views (CX-014) ──
  savedTableViews SavedTableView[]

  // ── QA-DB-04/05: denormalized tenant back-relations (FK + NOT-NULL, A4) ──
  // These mirror the child tables' direct `organizationId` column added for
  // org-scoped list/AR queries. They are denormalized — the canonical owner is
  // still Unit/PaymentPlan — so the relation names are suffixed `…Denorm`.
  leasesDenorm                  Lease[]                  @relation("LeaseOrg")
  reservationsDenorm            Reservation[]            @relation("ReservationOrg")
  paymentPlansDenorm            PaymentPlan[]            @relation("PaymentPlanOrg")
  paymentPlanInstallmentsDenorm PaymentPlanInstallment[] @relation("PaymentPlanInstallmentOrg")
}

enum OrgType {
  BROKERAGE
  PROPERTY_MANAGEMENT
  DEVELOPER
  MIXED
}

enum OrgAppStatus {
  ACTIVE
  PENDING_VERIFICATION
  EXPIRED
}

enum EntityType {
  ESTABLISHMENT
  COMPANY
  BRANCH
  PROFESSIONAL_ENTITY
  FOREIGN_COMPANY_BRANCH
  OTHER_ENTITY
}

enum LegalForm {
  SOLE_PROPRIETORSHIP
  LIMITED_LIABILITY_COMPANY
  JOINT_STOCK_COMPANY
  SIMPLIFIED_JOINT_STOCK_COMPANY
  GENERAL_PARTNERSHIP
  LIMITED_PARTNERSHIP
  PROFESSIONAL_COMPANY
  BRANCH_OF_COMPANY
  FOREIGN_BRANCH
  NON_PROFIT_ENTITY
  OTHER_LEGAL_FORM
}

enum RegistrationStatus {
  ACTIVE_REG
  EXPIRED_REG
  SUSPENDED_REG
  CANCELLED_REG
  UNDER_LIQUIDATION
  CLOSED_REG
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  name                    String?
  password                String
  role                    UserRole                 @default(USER)
  organizationId          String?
  organization            Organization?            @relation(fields: [organizationId], references: [id])
  accountType             String? // "individual" | "company"
  onboardingCompleted     Boolean                  @default(false)
  emailVerified           DateTime? // null = unverified → login denied (EMAIL_NOT_VERIFIED). Set on confirm. Existing rows backfilled to now().
  invitedBy               String? // userId of the person who invited this user
  invitedVia              String? // "registration" | "invitation" | "direct" | "join_request"
  customers               Customer[]               @relation("AssignedCustomers")
  assignedMaintenance     MaintenanceRequest[]     @relation("AssignedMaintenance")
  preferences             Json?
  resetTokens             PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notifications           Notification[]
  permissionRequests      PermissionRequest[]      @relation("PermissionRequests")
  reviewedRequests        PermissionRequest[]      @relation("ReviewedRequests")
  supportTickets          SupportTicket[]          @relation("SupportTickets")
  assignedTickets         SupportTicket[]          @relation("AssignedTickets")
  ticketMessages          TicketMessage[]          @relation("TicketMessages")
  sentInvitations         Invitation[]             @relation("SentInvitations")
  receivedInvitation      Invitation?              @relation("ReceivedInvitation")
  joinRequests            JoinRequest[]            @relation("UserJoinRequests")
  reviewedJoinRequests    JoinRequest[]            @relation("JoinReviewers")
  customerActivities      CustomerActivity[]       @relation("ActivityCreator")
  savedTableViews         SavedTableView[]
  lastActiveAt            DateTime? // Debounced sign-in / authed-request timestamp — powers admin-no-login KPIs
  isActive                Boolean                  @default(true) // false = deactivated → rejected at login + by getSessionOrThrow (SEC-003 revocation)
  tokenVersion            Int                      @default(0) // bumped on password reset/change + "sign out everywhere" → invalidates existing JWTs (SEC-003)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([organizationId])
  @@index([organizationId, lastActiveAt])
}

// ─── SavedTableView (CX-014 — DataTable personal saved views) ────────────────────
// Personal, DB-backed view configs for the shared DataTable (sort / filters /
// column visibility + order / density / page size). Scoped to (org, user, tableKey).
// `isShared` exists for a later org-wide-views feature — queries ignore it for now.
// §4: every required column carries @default so `db push` backfills existing rows.

model SavedTableView {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  tableKey       String
  name           String
  config         Json
  isShared       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, tableKey])
}

enum UserRole {
  SYSTEM_ADMIN
  SYSTEM_SUPPORT
  ADMIN
  MANAGER
  LEASING
  FINANCE
  AGENT
  TECHNICIAN
  USER
}

// ─── Unit ─────────────────────────────────────────────────────────────────────

model Unit {
  id                          String                      @id @default(cuid())
  number                      String
  type                        UnitType
  status                      UnitStatus                  @default(AVAILABLE)
  organizationId              String
  organization                Organization                @relation("UnitOrganization", fields: [organizationId], references: [id])
  area                        Float? // sqm
  price                       Decimal?                    @db.Decimal(14, 2) // Base/cost price
  markupPrice                 Decimal?                    @db.Decimal(14, 2) // Selling price (for sale/reservation)
  rentalPrice                 Decimal?                    @db.Decimal(14, 2) // Rental price (for lease contracts)
  floor                       Int? // Floor number
  buildingName                String?
  addressLine                 String?
  city                        String?
  district                    String?
  bedrooms                    Int? // Number of bedrooms
  bathrooms                   Int? // Number of bathrooms
  commercialStrategy          CommercialStrategy? // FR-08/21: SELL, LEASE, HOLD, etc.
  reservations                Reservation[]
  documents                   Document[]
  contracts                   Contract[]
  leases                      Lease[]
  maintenanceRequests         MaintenanceRequest[]
  preventivePlans             PreventiveMaintenancePlan[]
  customerInterests           Deal[]
  // ── Marketplace (cross-org trading) ──
  marketplaceStatus           MarketplaceListingStatus?
  currentMarketplaceListingId String?
  marketplaceListings         MarketplaceListing[]        @relation("UnitMarketplaceListings")
  transferredFromUnitId       String?
  transferredFromUnit         Unit?                       @relation("UnitTransferProvenance", fields: [transferredFromUnitId], references: [id])
  transferredToUnits          Unit[]                      @relation("UnitTransferProvenance")
  // QA-DB-05: immutable cross-org provenance snapshots (set once at transfer time,
  // never used in a WHERE filter — read only as per-row sentinels). No FK (cross-org,
  // must survive the other org's lifecycle), no @@index (never queried by these cols).
  transferredFromOrgId        String?
  transferredToOrgId          String?
  soldTransferredAt           DateTime?
  ownershipLockedReason       String?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt

  @@index([organizationId])
  @@index([transferredFromUnitId])
  @@index([organizationId, status])
}

// ─── Customer (Absher individual data aligned) ────────────────────────────────

model Customer {
  id                   String               @id @default(cuid())
  name                 String
  nameArabic           String? // Full name in Arabic
  email                String?
  phone                String
  nationalId           String? // Saudi ID / Iqama (10 digits, starts with 1 or 2)
  personType           PersonType? // saudi_citizen, resident, gcc_citizen, etc.
  gender               Gender?
  dateOfBirth          DateTime? // Gregorian DOB
  dateOfBirthHijri     String? // Hijri date as text (e.g. 1410-10-19)
  nationality          String? // e.g. "Saudi Arabian"
  nationalityCode      String? // ISO code e.g. "SA"
  maritalStatus        String? // single, married, divorced, widowed
  address              Json? // National address {region, city, district, streetName, buildingNumber, postalCode, additionalNumber, shortAddress}
  documentInfo         Json? // ID document {documentType, documentNumber, issueDate, expiryDate, issuingAuthority}
  nationalIdHash       String? // HMAC-SHA256 blind index (lib/encryption.ts hashForSearch) for exact search on encrypted nationalId
  phoneHash            String? // HMAC-SHA256 blind index (lib/encryption.ts hashForSearch) for exact search on encrypted phone (E.164-normalized)
  emailHash            String? // HMAC-SHA256 blind index (lib/encryption.ts hashForSearch) for exact search on encrypted email
  // RED: Buyer profile enhancements
  preferredLanguage    String?              @default("ar")
  authorizedSignatory  String? // For corporate buyers
  companyDocuments     Json? // For corporate buyers
  // ZATCA Track C buyer party (R4 — D18): plaintext, non-unique business identifiers
  // (NOT encrypted — they ride encryptCustomerData's passthrough). Drive B2B-vs-B2C
  // routing: a COMPANY with a valid VAT + CR + complete address → standard clearance.
  customerKind         CustomerKind?
  vatNumber            String? // 15-digit VAT (3...3); plaintext, non-unique
  crNumber             String? // 10-digit Commercial Registration; plaintext
  companyNameAr        String?
  companyNameEn        String?
  status               CustomerStatus       @default(NEW)
  source               String?
  budget               Decimal?             @db.Decimal(14, 2) // Customer's budget in SAR
  propertyTypeInterest String? // e.g. "APARTMENT", "VILLA", "OFFICE"
  lostReason           String? // Reason for LOST status
  organizationId       String
  organization         Organization         @relation(fields: [organizationId], references: [id])
  agentId              String?
  agent                User?                @relation("AssignedCustomers", fields: [agentId], references: [id])
  reservations         Reservation[]
  contracts            Contract[]
  leases               Lease[]
  documents            Document[]
  activities           CustomerActivity[]
  propertyInterests    Deal[]
  marketplaceInquiries MarketplaceInquiry[] @relation("MarketplaceInquiryCustomer")
  tenantDocuments      TenantDocument[]     @relation("CustomerTenantDocs")
  // Timestamp the customer entered its CURRENT pipeline stage (status). Distinct from
  // updatedAt (which any edit bumps). Set on status change in updateCustomerStatus.
  // @default(now()) safely backfills existing rows on `db push` (nullable + defaulted).
  stageEnteredAt       DateTime?            @default(now())
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  // NOTE: @@index([nationalId]) removed in v4.18.0 — it indexed random-IV ciphertext
  // (never equality-matched), so it was pure write-amplification dead weight.

  @@index([organizationId])
  @@index([agentId])
  // QA-DB-06: tenant-leading composite for the CRM status-filtered customer list.
  @@index([organizationId, status])
  // Blind-index lookups are tenant-scoped exact matches. Composite btree indexes
  // (hash-type indexes are single-column equality-only and can't be tenant-scoped).
  @@index([organizationId, phoneHash])
  @@index([organizationId, emailHash])
  @@index([organizationId, nationalIdHash])
  @@index([organizationId, vatNumber]) // ZATCA Track C — B2B buyer matching (non-unique, D18)
}

enum PersonType {
  SAUDI_CITIZEN
  RESIDENT
  GCC_CITIZEN
  VISITOR
  OTHER_PERSON
}

enum Gender {
  MALE
  FEMALE
}

enum CustomerStatus {
  NEW
  CONTACTED
  INTERESTED
  QUALIFIED
  VIEWING
  NEGOTIATION
  RESERVED
  CONVERTED
  LOST
  ACTIVE_TENANT
  PAST_TENANT
}

// ─── Reservation ──────────────────────────────────────────────────────────────

model Reservation {
  id                   String                 @id @default(cuid())
  customerId           String
  customer             Customer               @relation(fields: [customerId], references: [id])
  unitId               String
  unit                 Unit                   @relation(fields: [unitId], references: [id])
  userId               String? // The agent/user who created the reservation
  status               ReservationStatus      @default(PENDING)
  expiresAt            DateTime
  amount               Decimal?               @db.Decimal(14, 2)
  // RED: Enhanced reservation fields
  depositRequired      Boolean                @default(false)
  depositAmount        Decimal?               @db.Decimal(14, 2)
  depositPaidAt        DateTime?
  extensions           ReservationExtension[]
  // ── Marketplace cross-org bridge (null for normal single-org deals) ──
  marketplaceInquiryId String?                @unique
  marketplaceInquiry   MarketplaceInquiry?    @relation(fields: [marketplaceInquiryId], references: [id])
  // QA-DB-05: immutable cross-org snapshots — no FK (cross-org), no @@index (not queried).
  buyerOrgId           String?
  sellerOrgId          String?
  // QA-DB-04 (A4): denormalized tenant column — NOT-NULL + FK, backfilled via
  // 2026-06-orgid-backfill.sql ← unit.organizationId before the push.
  organizationId       String
  organization         Organization           @relation("ReservationOrg", fields: [organizationId], references: [id])
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([customerId])
  @@index([unitId])
  @@index([userId])
  @@index([expiresAt, status])
  // QA-DB-04/06: tenant-leading composite — also serves org-only lookups via its
  // leading column, so no standalone @@index([organizationId]) is needed (effective
  // once organizationId is backfilled — see 2026-06-orgid-backfill.sql).
  @@index([organizationId, status])
}

// RED: Reservation extension requests
model ReservationExtension {
  id            String          @id @default(cuid())
  reservationId String
  reservation   Reservation     @relation(fields: [reservationId], references: [id])
  requestedBy   String
  approvedBy    String?
  newExpiresAt  DateTime
  reason        String?
  status        ExtensionStatus @default(PENDING_EXTENSION)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([reservationId])
}

enum ExtensionStatus {
  PENDING_EXTENSION
  APPROVED_EXTENSION
  REJECTED_EXTENSION
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id         String         @id @default(cuid())
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id])
  unitId     String
  unit       Unit           @relation(fields: [unitId], references: [id])
  userId     String? // The agent/user who created the contract
  status     ContractStatus @default(DRAFT)
  type       ContractType   @default(SALE)
  fileUrl    String?
  amount     Decimal        @db.Decimal(14, 2)
  signedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Contract identification
  contractNumber String? @unique

  // Lease link (type=LEASE only)
  leaseId String? @unique
  lease   Lease?  @relation(fields: [leaseId], references: [id])

  // Ejar fields (type=LEASE)
  paymentFrequency          RecurrenceType?
  securityDeposit           Decimal?        @db.Decimal(14, 2)
  autoRenewal               Boolean?
  maintenanceResponsibility String? // "LANDLORD" or "TENANT"
  noticePeriodDays          Int?

  // Sale fields (type=SALE)
  deliveryDate DateTime?

  // Shared
  termsAndConditions   String?
  notes                String?
  // RED: Amount breakdown
  grossAmount          Decimal?     @db.Decimal(14, 2)
  discountAmount       Decimal?     @db.Decimal(14, 2)
  netAmount            Decimal?     @db.Decimal(14, 2)
  // RED: Template & signatures
  templateId           String?
  templateVersion      Int?
  buyerSignedAt        DateTime?
  buyerSignatureUrl    String?
  pdfPreviewUrl        String?
  // RED: Relations
  paymentPlan          PaymentPlan?
  // ── Marketplace cross-org bridge (null for normal single-org contracts) ──
  // QA-DB-05: buyer/sellerOrgId are immutable cross-org snapshots — written at deal
  // time, never used in a WHERE filter. No FK (cross-org), no @@index (not queried).
  marketplaceInquiryId String?
  buyerOrgId           String?
  sellerOrgId          String?

  // Documents linked to this contract
  documents Document[]

  @@index([customerId])
  @@index([unitId])
  @@index([userId])
  @@index([leaseId])
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
  VOID
}

enum ContractType {
  SALE
  LEASE
}

// RED: Payment Plans (linked 1:1 to Contract)
model PaymentPlan {
  id             String                   @id @default(cuid())
  contractId     String                   @unique
  contract       Contract                 @relation(fields: [contractId], references: [id])
  name           String?
  totalAmount    Decimal                  @db.Decimal(14, 2)
  downPayment    Decimal?                 @db.Decimal(14, 2)
  status         PaymentPlanStatus        @default(DRAFT_PLAN)
  installments   PaymentPlanInstallment[]
  // QA-DB-04 (A4): denormalized tenant column — NOT-NULL + FK. Backfilled via
  // 2026-06-orgid-backfill.sql ← unit.organizationId (through contract.unitId).
  organizationId String
  organization   Organization             @relation("PaymentPlanOrg", fields: [organizationId], references: [id])
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([organizationId])
}

enum PaymentPlanStatus {
  DRAFT_PLAN
  ACTIVE_PLAN
  COMPLETED_PLAN
  CANCELLED_PLAN
}

model PaymentPlanInstallment {
  id                String            @id @default(cuid())
  paymentPlanId     String
  paymentPlan       PaymentPlan       @relation(fields: [paymentPlanId], references: [id])
  installmentNumber Int
  amount            Decimal           @db.Decimal(14, 2)
  dueDate           DateTime
  status            InstallmentStatus @default(UNPAID)
  paidAt            DateTime?
  paidAmount        Decimal?          @db.Decimal(14, 2)
  paymentMethod     String?
  referenceNumber   String?
  paymentReference  String?
  // QA-DB-04 (A4): denormalized tenant column — NOT-NULL + FK, backfilled via
  // 2026-06-orgid-backfill.sql ← paymentPlan.organizationId before the push.
  organizationId    String
  organization      Organization      @relation("PaymentPlanInstallmentOrg", fields: [organizationId], references: [id])
  tenantDocuments   TenantDocument[]  @relation("PpiTenantDocs")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([paymentPlanId, paymentReference])
  @@index([paymentPlanId])
  // QA-DB-04/06: tenant-leading composite — also serves org-only lookups via its
  // leading column, so no standalone @@index([organizationId]) is needed (effective
  // once organizationId is backfilled — see 2026-06-orgid-backfill.sql).
  @@index([organizationId, status])
}

enum InstallmentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

// RED: Contract Templates
model ContractTemplate {
  id             String       @id @default(cuid())
  name           String
  nameArabic     String?
  type           ContractType
  version        Int          @default(1)
  content        String // HTML template with {{vars}}
  isActive       Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

enum UnitType {
  APARTMENT
  VILLA
  OFFICE
  RETAIL
  WAREHOUSE
  PARKING
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  MAINTENANCE
  SUSPENDED // RED: temporarily blocked from transactions
  WITHDRAWN // RED: permanently removed from inventory
  HANDED_OVER // RED: handover to buyer completed
}

// ─── Lease ────────────────────────────────────────────────────────────────────

model Lease {
  id             String            @id @default(cuid())
  unitId         String
  unit           Unit              @relation(fields: [unitId], references: [id])
  customerId     String
  customer       Customer          @relation(fields: [customerId], references: [id])
  startDate      DateTime
  endDate        DateTime
  totalAmount    Decimal           @db.Decimal(14, 2)
  status         LeaseStatus       @default(DRAFT)
  installments   RentInstallment[]
  ejarContractId String? // For Ejar integration
  contract       Contract? // Linked contract (reverse relation)
  // QA-DB-04 (A4): denormalized tenant column — NOT-NULL + FK, backfilled via
  // 2026-06-orgid-backfill.sql ← unit.organizationId before the push.
  organizationId String
  organization   Organization      @relation("LeaseOrg", fields: [organizationId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([unitId])
  @@index([customerId])
  @@index([organizationId])
}

enum LeaseStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  EXPIRED
  TERMINATED
}

// ─── Rent Installment ─────────────────────────────────────────────────────────

model RentInstallment {
  id               String           @id @default(cuid())
  leaseId          String
  lease            Lease            @relation(fields: [leaseId], references: [id])
  dueDate          DateTime
  amount           Decimal          @db.Decimal(14, 2)
  status           PaymentStatus    @default(UNPAID)
  paidAt           DateTime?
  paidAmount       Decimal?         @db.Decimal(14, 2)
  paymentMethod    String?
  referenceNumber  String?
  paymentReference String?
  notes            String?
  payments         RentPayment[] // I2: append-only ledger of payment/reversal/refund/adjustment txns
  tenantDocuments  TenantDocument[] @relation("RentInstallmentTenantDocs")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([leaseId, paymentReference])
  @@index([leaseId])
}

// ─── RentPayment (I2 append-only ledger) ────────────────────────────────────
// One row per money movement against an installment. NO `updatedAt`: rows are
// immutable by contract (append-only), which also sidesteps the §4 @updatedAt
// populated-table `db push` hazard. `amount` is signed — PAYMENT/ADJUSTMENT > 0,
// REVERSAL/REFUND < 0. `createdById` is intentionally a bare String with no FK
// relation to User (keeps the User model untouched). Idempotency is enforced by
// the [installmentId, idempotencyKey] unique constraint.

model RentPayment {
  id             String          @id @default(cuid())
  installmentId  String
  installment    RentInstallment @relation(fields: [installmentId], references: [id])
  leaseId        String
  amount         Decimal         @db.Decimal(14, 2) // signed: PAYMENT/ADJUSTMENT > 0; REVERSAL/REFUND < 0
  txType         RentPaymentType @default(PAYMENT)
  idempotencyKey String
  channel        String?
  reference      String?
  notes          String?
  createdById    String?
  createdAt      DateTime        @default(now())

  @@unique([installmentId, idempotencyKey])
  @@index([installmentId])
  @@index([leaseId])
  @@index([installmentId, txType])
}

enum RentPaymentType {
  PAYMENT
  REVERSAL
  REFUND
  ADJUSTMENT
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

// ─── Document ─────────────────────────────────────────────────────────────────

model Document {
  id             String            @id @default(cuid())
  name           String
  url            String
  type           String // file extension or mime type
  category       DocCategory       @default(GENERAL)
  size           Int? // in bytes
  customerId     String?
  customer       Customer?         @relation(fields: [customerId], references: [id])
  unitId         String?
  unit           Unit?             @relation(fields: [unitId], references: [id])
  contractId     String?
  contract       Contract?         @relation(fields: [contractId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  userId         String?
  version        Int               @default(1)
  versions       DocumentVersion[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([customerId])
  @@index([unitId])
  @@index([contractId])
  @@index([organizationId])
}

enum DocCategory {
  GENERAL
  LEGAL
  CONTRACT
  MARKETING
  FINANCE
}

// ─── Maintenance Request ──────────────────────────────────────────────────────

model MaintenanceRequest {
  id           String              @id @default(cuid())
  title        String
  description  String?
  type         String? // Legacy field (electrical, plumbing, etc.)
  category     MaintenanceCategory @default(GENERAL)
  status       MaintenanceStatus   @default(OPEN)
  priority     MaintenancePriority @default(MEDIUM)
  unitId       String
  unit         Unit                @relation(fields: [unitId], references: [id])
  assignedToId String?
  assignedTo   User?               @relation("AssignedMaintenance", fields: [assignedToId], references: [id])

  // Scheduling & deadlines
  scheduledDate DateTime?
  dueDate       DateTime?
  completedAt   DateTime?

  // Cost tracking
  estimatedCost Decimal? @db.Decimal(14, 2)
  actualCost    Decimal? @db.Decimal(14, 2)
  laborHours    Float?

  // Work order notes
  notes String?

  // Preventive maintenance link
  isPreventive     Boolean                    @default(false)
  preventivePlanId String?
  preventivePlan   PreventiveMaintenancePlan? @relation(fields: [preventivePlanId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([unitId])
  @@index([assignedToId])
  @@index([preventivePlanId])
  @@index([status])
  @@index([dueDate])
  @@index([category])
  // QA-DB-06: tenant-leading composite for the open-tickets-by-org dashboard query.
  @@index([organizationId, status])
}

// ─── Preventive Maintenance Plan ──────────────────────────────────────────────

model PreventiveMaintenancePlan {
  id          String              @id @default(cuid())
  title       String
  description String?
  category    MaintenanceCategory @default(GENERAL)
  priority    MaintenancePriority @default(MEDIUM)

  // Scope
  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id])

  // Recurrence
  recurrenceType     RecurrenceType
  recurrenceInterval Int            @default(1)
  startDate          DateTime
  endDate            DateTime?
  nextRunDate        DateTime

  // Cost estimation
  estimatedCost  Decimal? @db.Decimal(14, 2)
  estimatedHours Float?

  // Assignment
  assignToId String?

  // Status
  isActive Boolean @default(true)

  // Organization
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Generated work orders
  workOrders MaintenanceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([nextRunDate])
  @@index([isActive])
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceCategory {
  HVAC
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  FIRE_SAFETY
  ELEVATOR
  CLEANING
  LANDSCAPING
  PEST_CONTROL
  GENERAL
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

// ─── Password Reset Token (NIST SP 800-63B) ─────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token")
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
}

// ─── Email Verification Token (OWASP: hash-at-rest, single-use, 24h expiry) ──
// Stores ONLY the SHA-256 hash of the token (`tokenHash`); the raw token lives
// only in the emailed link. Single-use via an atomic updateMany(usedAt: null).
// GET /auth/verify-email renders a confirm page; POST activates (so email-scanner
// prefetch can't consume the token). Expired/used rows purged by the daily cron.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
}

// ─── Audit Log (PDPL Article 32 compliance) ────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  userId         String
  userEmail      String
  userRole       String
  action         String // CREATE, READ, UPDATE, DELETE, READ_PII, EXPORT, LOGIN, LOGOUT
  resource       String // Customer, Contract, Unit, etc.
  resourceId     String?
  metadata       Json?
  changeSnapshot Json? // RED: {before: {...}, after: {...}} for UPDATE, full payload for CREATE
  fieldChanges   Json? // RED: [{field, oldValue, newValue}, ...] auto-computed diff
  ipAddress      String?
  organizationId String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([resource, action])
}

// ─── Cookie consent (PDPL documented-consent audit trail) ───────────────────
// Server-side record of each cookie-consent choice — defensible proof beyond
// the client `mimaric-consent` cookie (which can be cleared). No FK to User:
// like AuditLog, it is an append-only trail that must survive user deletion.
model ConsentLog {
  id          String   @id @default(cuid())
  userId      String? // null for anonymous (pre-login) visitors
  version     Int // consent policy/banner version at time of choice
  analytics   Boolean // the opt-in category decision
  necessary   Boolean  @default(true)
  locale      String // "ar" | "en" — language the notice was shown in
  method      String // "banner" | "preferences"
  ipTruncated String? // IP minimized to /24 (IPv4) for data minimization
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Commercial Strategy (FR-08/21) ─────────────────────────────────────────

enum CommercialStrategy {
  SELL
  LEASE
  HOLD
  TRANSFER
  COMMUNITY
}

// ─── Notification (FR-45) ───────────────────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  type           String // PAYMENT_DUE, PAYMENT_OVERDUE, LEASE_EXPIRY, MAINTENANCE_UPDATE
  title          String
  titleEn        String?
  message        String
  messageEn      String?
  link           String?
  read           Boolean  @default(false)
  organizationId String? // D29: nullable so platform-staff alerts (no org) can be targeted via notifyPlatformStaff()
  createdAt      DateTime @default(now())

  @@index([userId, read])
  @@index([organizationId])
}

// ─── Permission Request (Help Dashboard) ────────────────────────────────────

model PermissionRequest {
