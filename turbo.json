{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["DATABASE_URL", "AUTH_SECRET", "AUTH_TRUST_HOST", "AUTH_URL", "APP_URL", "NEXT_PUBLIC_APP_URL", "NEXTAUTH_URL", "PII_ENCRYPTION_KEY", "PII_HASH_PEPPER"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["DATABASE_URL", "AUTH_SECRET", "AUTH_TRUST_HOST", "AUTH_URL", "APP_URL", "NEXT_PUBLIC_APP_URL", "NEXTAUTH_URL", "NEXT_PUBLIC_API_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "^db:generate"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    }
  }
}
